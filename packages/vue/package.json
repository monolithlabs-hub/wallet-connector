{
  "name": "@monolithlabs/wallet-connect-vue",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsup && vue-tsc -p tsconfig.build.json",
    "test": "vitest run --coverage",
    "lint": "eslint . --max-warnings=0",
    "typecheck": "vue-tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "@monolithlabs/wallet-connect-core": "workspace:*",
    "@monolithlabs/wallet-connect-ui": "workspace:*"
  },
  "peerDependencies": {
    "vue": "^3.5.0"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^6.0.6",
    "@vue/test-utils": "^2.4.10",
    "unplugin-vue": "^7.2.0",
    "vue": "^3.5.34",
    "vue-tsc": "^3.2.8"
  }
}

{
  "name": "@monolithlabs-hub/wallet-connect-react",
  "version": "1.1.0",
  "description": "React bindings for @monolithlabs-hub/wallet-connect: useWallet() hook, WalletConnectProvider, and a ready-made <ConnectButton/> with SIWS support.",
  "keywords": [
    "solana",
    "wallet",
    "wallet-connect",
    "react",
    "react-hook",
    "sign-in-with-solana",
    "siws",
    "phantom",
    "solflare",
    "backpack",
    "web3"
  ],
  "homepage": "https://github.com/monolithlabs-hub/wallet-connector#readme",
  "bugs": {
    "url": "https://github.com/monolithlabs-hub/wallet-connector/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/monolithlabs-hub/wallet-connector.git",
    "directory": "packages/react"
  },
  "license": "MIT",
  "author": "Monolith Labs",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist",
    "LICENSE"
  ],
  "sideEffects": false,
  "engines": {
    "node": ">=18.18"
  },
  "publishConfig": {
    "access": "public",
    "provenance": false
  },
  "scripts": {
    "build": "tsup",
    "test": "vitest run --coverage",
    "lint": "eslint . --max-warnings=0",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "prepack": "cp ../../LICENSE ."
  },
  "dependencies": {
    "@monolithlabs-hub/wallet-connect-core": "workspace:*",
    "@monolithlabs-hub/wallet-connect-ui": "workspace:*"
  },
  "peerDependencies": {
    "react": ">=19"
  },
  "devDependencies": {
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "react": "^19.2.6",
    "react-dom": "^19.2.6"
  }
}

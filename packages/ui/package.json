{
  "name": "@monolithlabs-hub/wallet-connect-ui",
  "version": "1.0.2",
  "description": "Headless UI primitives for @monolithlabs-hub/wallet-connect: framework-agnostic modal lifecycle, focus trap, and wallet-list rendering helpers.",
  "keywords": [
    "solana",
    "wallet",
    "wallet-connect",
    "headless-ui",
    "modal",
    "focus-trap",
    "accessibility",
    "siws",
    "web3"
  ],
  "homepage": "https://github.com/monolithlabs-hub/wallet-connector#readme",
  "bugs": {
    "url": "https://github.com/monolithlabs-hub/wallet-connector/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/monolithlabs-hub/wallet-connector.git",
    "directory": "packages/ui"
  },
  "license": "MIT",
  "author": "Monolith Labs",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist",
    "LICENSE"
  ],
  "sideEffects": false,
  "engines": {
    "node": ">=18.18"
  },
  "publishConfig": {
    "access": "public",
    "provenance": false
  },
  "scripts": {
    "build": "tsup",
    "test": "vitest run --coverage",
    "lint": "eslint . --max-warnings=0",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "prepack": "cp ../../LICENSE ."
  },
  "dependencies": {}
}
